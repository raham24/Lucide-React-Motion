{
  "name": "lucide-react-motion",
  "version": "0.0.1",
  "description": "Lucide icons as animated React components, powered by Motion.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "require": "./dist/manifest.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "prebuild": "pnpm generate",
    "build": "tsup",
    "predev": "pnpm generate",
    "dev": "tsup --watch",
    "clean": "rm -rf dist src/generated",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint configured)\""
  },
  "peerDependencies": {
    "motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "lucide-static": "^1.16.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "keywords": [
    "lucide",
    "icons",
    "react",
    "motion",
    "framer-motion",
    "animation",
    "svg"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
